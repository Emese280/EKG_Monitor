{
  "name": "vitals-dashboard-backend",
  "version": "1.0.0",
  "description": "Életjelek vizualizáló dashboard - Backend",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
